<?xml version="1.0" encoding="utf-8"?>
<!--
    AccessibilityService configuration.
    - canRetrieveWindowContent: lets us read the accessibility node tree (screen text, buttons)
    - canPerformGestures: lets us tap, swipe, type on behalf of the user
    - canTakeScreenshot: lets us capture the current screen (API 30+)
    - accessibilityEventTypes: which events we listen to
-->
<accessibility-service
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:accessibilityEventTypes="typeWindowStateChanged|typeWindowContentChanged|typeViewFocused"
    android:accessibilityFeedbackType="feedbackGeneric"
    android:accessibilityFlags="flagReportViewIds|flagRetrieveInteractiveWindows|flagRequestFilterKeyEvents"
    android:canRetrieveWindowContent="true"
    android:canPerformGestures="true"
    android:canTakeScreenshot="true"
    android:description="@string/accessibility_service_description"
    android:notificationTimeout="100"
    android:settingsActivity=".MainActivity"
    android:summary="@string/accessibility_service_summary" />
